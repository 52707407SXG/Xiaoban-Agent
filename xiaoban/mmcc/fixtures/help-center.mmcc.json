{
  "contractVersion": "mystand.module-capability.v0.1",
  "moduleId": "help-center",
  "packageName": "@mystand/help-center",
  "version": "0.1.0",
  "displayName": "帮助中心",
  "owner": "core",
  "status": "installed",
  "category": "knowledge",
  "capabilities": {
    "provides": ["help.search", "help.read"],
    "requires": []
  },
  "permissions": [
    {
      "capability": "help.search",
      "roles": ["owner", "admin", "manager", "staff", "visitor"],
      "scopes": ["public", "company"],
      "defaultGrant": true
    },
    {
      "capability": "help.read",
      "roles": ["owner", "admin", "manager", "staff", "visitor"],
      "scopes": ["public", "company"],
      "defaultGrant": true
    }
  ],
  "dataScopes": [
    {
      "namespace": "help_documents",
      "ownerScope": "site",
      "recordKeyPattern": "help:{documentId}"
    }
  ],
  "events": {
    "emits": ["help.article.viewed"],
    "subscribes": []
  },
  "agent": {
    "tools": [],
    "contextProviders": [
      {
        "providerId": "current_page_help",
        "description": "当前页面或模块相关的帮助中心摘要。",
        "requiredCapability": "help.read",
        "dataScopes": ["help_documents"]
      }
    ]
  },
  "migrations": {
    "hasSchemaMigration": false,
    "requiresManualApproval": false
  }
}
