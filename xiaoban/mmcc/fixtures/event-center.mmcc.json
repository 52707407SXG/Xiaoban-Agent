{
  "contractVersion": "mystand.module-capability.v0.1",
  "moduleId": "event-center",
  "packageName": "@mystand/event-center",
  "version": "0.1.0",
  "displayName": "事件中心",
  "owner": "core",
  "status": "installed",
  "category": "workflow",
  "capabilities": {
    "provides": ["event.read", "event.create", "event.update", "event.cancel"],
    "requires": []
  },
  "permissions": [
    {
      "capability": "event.read",
      "roles": ["owner", "admin", "manager", "staff"],
      "scopes": ["self", "team", "company"],
      "defaultGrant": true
    },
    {
      "capability": "event.create",
      "roles": ["owner", "admin", "manager", "staff"],
      "scopes": ["self", "team"],
      "defaultGrant": false
    },
    {
      "capability": "event.update",
      "roles": ["owner", "admin", "manager", "staff"],
      "scopes": ["self", "team"],
      "defaultGrant": false
    },
    {
      "capability": "event.cancel",
      "roles": ["owner", "admin", "manager"],
      "scopes": ["self", "team"],
      "defaultGrant": false
    }
  ],
  "dataScopes": [
    {
      "namespace": "event_records",
      "ownerScope": "company",
      "recordKeyPattern": "event:{eventId}"
    }
  ],
  "events": {
    "emits": ["event.created", "event.updated", "event.cancelled", "event.due"],
    "subscribes": ["task.completed", "module.reminder.requested"]
  },
  "agent": {
    "tools": [],
    "contextProviders": [
      {
        "providerId": "pending_events_summary",
        "description": "当前用户授权范围内的待处理事件摘要。",
        "requiredCapability": "event.read",
        "dataScopes": ["event_records"]
      }
    ]
  },
  "migrations": {
    "hasSchemaMigration": false,
    "requiresManualApproval": false
  }
}
